# Copy this file to .env and adjust values for local development.
# In production (Docker), set these via docker-compose.yml environment section.

# IMPORTANT: generate a real random key before going into production.
# Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-random-32-char-string!!

# Default admin password created on first boot. Change it via the Users page.
ADMIN_PASSWORD=admin

# SQLite database path. The directory must be writable.
# In Docker this is a named volume; locally you can use any path.
DATABASE_URL=sqlite:///./dev.db

# Docker image name for the tecsuite container.
TECSUITE_IMAGE=tec-suite
